# --- Server ---
PORT=4000
NODE_ENV=development

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Service-role key: SERVER ONLY. Never ship this to the mobile app.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...
# Sonnet for cost, Opus for hard cases. See docs for model routing.
CLAUDE_MODEL=claude-sonnet-4-6

# --- Embeddings (RAG) ---
# Voyage AI is cheaper than OpenAI for embeddings; either works.
VOYAGE_API_KEY=
EMBEDDING_DIM=1536

# --- Pinecone (optional — pgvector is the default) ---
PINECONE_API_KEY=
PINECONE_INDEX=aftercare-resources

# --- Twilio (crisis SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
