# --- Server ---
PORT=4000
NODE_ENV=development

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Service-role key: SERVER ONLY. Never ship this to the mobile app.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# DB password for `supabase link` / `db push`.
SUPABASE_DB_PASSWORD=

# --- Anthropic (Claude) ---
# Leave blank in dev/test to use the built-in fake responder.
ANTHROPIC_API_KEY=sk-ant-...
# Sonnet for cost, Opus for hard cases. See docs for model routing.
CLAUDE_MODEL=claude-sonnet-4-6

# --- Embeddings (RAG, pgvector) ---
# Provider: 'openai' (text-embedding-3-small, 1536 dims) or 'voyage'.
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
VOYAGE_API_KEY=
EMBEDDING_DIM=1536

# --- Twilio (crisis SMS + reminders) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Cron (background jobs) ---
# Shared secret for POST /internal/cron. Generate a long random string.
CRON_SECRET=
